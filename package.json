{
  "name": "filedrop-advanced",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "vite frontend",
    "dev:worker": "wrangler dev worker/index.js --local --ip 0.0.0.0 --port 8787",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:worker\"",
    "build": "vite build frontend",
    "deploy:worker": "wrangler deploy worker/index.js",
    "deploy": "npm run build && npm run deploy:worker"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "vite": "^5.0.0",
    "wrangler": "^4.98.0"
  }
}
